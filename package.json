{
  "name": "@entelligentsia/forgecli",
  "version": "0.8.0",
  "description": "Forge SDLC ported onto @earendil-works/pi-coding-agent — production launcher with three bin aliases (forge/forgecli/4ge). Bundles a curated fork of pi-coding-agent vendored under earendil-works names.",
  "license": "MIT",
  "author": "Entelligentsia",
  "homepage": "https://github.com/Entelligentsia/forge-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Entelligentsia/forge-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Entelligentsia/forge-cli/issues"
  },
  "type": "module",
  "bin": {
    "forge": "./dist/bin/forge.js",
    "forgecli": "./dist/bin/forge.js",
    "4ge": "./dist/bin/forge.js"
  },
  "main": "./dist/extensions/forgecli/index.js",
  "types": "./dist/extensions/forgecli/index.d.ts",
  "files": [
    "dist",
    "agents",
    "prompts",
    "registry",
    "themes",
    "workflows",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./dist/extensions/forgecli/index.js"
    ],
    "skills": [
      "./dist/forge-payload/skills"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "forge": {
    "bundledVersion": "0.43.19",
    "forgeRoot": "../forge/forge"
  },
  "scripts": {
    "build": "node scripts/build-payload.cjs && tsc",
    "prepack": "node scripts/prepack-fix-bundled.cjs",
    "postpack": "node scripts/prepack-fix-bundled.cjs --restore",
    "build:tsc-only": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src test",
    "sync-forge": "node scripts/sync-forge.cjs"
  },
  "bundledDependencies": [
    "@earendil-works/pi-coding-agent",
    "@earendil-works/pi-agent-core",
    "@earendil-works/pi-ai",
    "@earendil-works/pi-tui",
    "js-yaml"
  ],
  "dependencies": {
    "@earendil-works/pi-coding-agent": "file:./vendor-pi/earendil-works-pi-coding-agent-0.75.1-forge.1.tgz",
    "@earendil-works/pi-agent-core": "file:./vendor-pi/earendil-works-pi-agent-core-0.75.1.tgz",
    "@earendil-works/pi-ai": "file:./vendor-pi/earendil-works-pi-ai-0.75.1.tgz",
    "@earendil-works/pi-tui": "file:./vendor-pi/earendil-works-pi-tui-0.75.1.tgz",
    "js-yaml": "^4.1.0",
    "typebox": "^1.1.24"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "0.75.1-forge.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.3.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
